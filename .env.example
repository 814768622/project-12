APP_ENV=development
APP_SECRET=change-me
LOG_LEVEL=INFO
TZ=America/Toronto
PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/okeanos
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

CF7_WEBHOOK_SECRET=change-me
TWILIO_WEBHOOK_SECRET=change-me
GMAIL_WEBHOOK_SECRET=change-me
GMAIL_APPROVAL_LABEL=Okeanos-Approvals

HOURLY_SYNC_CRON=0 * * * *
ALERT_CHECK_CRON=15 * * * *
WEEKLY_REPORT_CRON=0 8 * * 1

EMAIL_MAX_PER_WEEK=3
SMS_COOLDOWN_HOURS=48
SMS_SEND_WINDOW_START=09:00
SMS_SEND_WINDOW_END=20:00
